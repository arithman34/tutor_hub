# Postgres superuser
POSTGRES_USER=your-postgres-user-here
POSTGRES_PASSWORD=your-postgres-password-here

# App database user
APP_DB_USER=your-app-db-user-here
APP_DB_PASSWORD=your-strong-password-here
APP_DB_NAME=your-app-db-name-here

# FastAPI secret key
SECRET_KEY=your-secret-key-here

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here